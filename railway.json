{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && pnpm --filter graceful-heart-server build"
  },
  "deploy": {
    "startCommand": "node $(find . -name index.js | grep dist | head -n 1)",
    "restartPolicyType": "ON_FAILURE"
  }
}