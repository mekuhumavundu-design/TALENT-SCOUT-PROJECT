{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install && pnpm --filter graceful-heart-server build"
  },
  "deploy": {
    "startCommand": "PORT=5000 HOST=0.0.0.0 node apps/server/dist/index.js",
    "restartPolicyType": "ON_FAILURE"
  }
}